# Example environment variables for production/docker
# Copy this to ".env" and fill with real secrets before deploying.

# App
PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Database
DB_URL=jdbc:postgresql://postgres:5432/reservas
DB_USERNAME=reservas
DB_PASSWORD=changeme

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
APP_JWT_SECRET=replace-with-a-secure-long-secret-key-please-change
APP_JWT_ACCESS_VALIDITY_MS=900000
APP_JWT_REFRESH_VALIDITY_MS=604800000

# Frontend origins allowed by CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional observability
# SENTRY_DSN=
